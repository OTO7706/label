{
  "name": "label-designer",
  "version": "1.0.0",
  "description": "Aplicación de escritorio para diseñar y exportar etiquetas a PDF",
  "main": "public/electron.js",
  "homepage": "./",
  "author": "OTO7706",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "fabric": "^5.3.0",
    "jspdf": "^2.5.1",
    "html2canvas": "^1.4.1",
    "zustand": "^4.4.1",
    "lucide-react": "^0.263.1"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "electron": "^25.0.0",
    "electron-builder": "^24.6.4",
    "electron-dev-utils": "^1.1.8"
  },
  "scripts": {
    "react-start": "react-scripts start",
    "react-build": "react-scripts build",
    "electron-start": "wait-on http://localhost:3000 && electron .",
    "start": "concurrently \"npm run react-start\" \"npm run electron-start\"",
    "build": "npm run react-build && electron-builder",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
